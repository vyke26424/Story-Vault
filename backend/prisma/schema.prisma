// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. USER & AUTH
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  avatarUrl String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address      Address[]
  cart         Cart?
  orders       Order[]
  reviews      Review[]
  feedbacks    Feedback[]
  refreshToken RefreshToken[]
}

enum Role {
  CUSTOMER
  ADMIN
  SHIPPER
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  // token     String   @unique
  device    String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  phone     String?
  street    String?
  ward      String?
  district  String?
  city      String?
  isDefault Boolean?

  orders Order[]

  @@index([userId, phone])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String? // Có thể null nếu khách vãng lai (chưa đăng nhập)
  email     String? // Bắt buộc nhập nếu là khách vãng lai
  type      String // Loại: Báo lỗi, Góp ý, Khiếu nại...
  content   String   @db.Text
  status    String   @default("PENDING") // PENDING (Chưa xử lý), RESOLVED (Đã xử lý)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String? @db.Text

  series Series[]
}

model Series {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique
  description String? @db.Text
  coverImage  String?

  author    String?
  publisher String?

  type         Type
  status       Status
  totalVolumes Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories Category[]
  volumes    Volume[]
  reviews    Review[]

  @@index([title])
  @@index([isActive, createdAt(sort: Desc)])
}

enum Type {
  MANGA
  LIGHT_NOVEL
  NOVEL
  COMIC
  BOOK
}

enum Status {
  ONGOING
  COMPLETED
  HIATUS
}

model Volume {
  id            String    @id @default(uuid())
  seriesId      String
  series        Series    @relation(fields: [seriesId], references: [id])
  title         String?
  coverImage    String?
  price         Decimal   @db.Decimal(10, 2)
  originalPrice Decimal?  @db.Decimal(10, 2)
  stock         Int       @default(0)
  isbn          String?   @unique
  publishDate   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  volumeNumber  Int       @default(1)
  updatedAt     DateTime  @updatedAt
  soldCount     Int       @default(0)

  cartItems     CartItem[]
  orderItems    OrderItem[]
  inventoryLogs InventoryTransaction[]

  @@index([title])
  @@index([seriesId])
}

// ==========================================
// 3. INVENTORY MANAGEMENT
// ==========================================
model InventoryTransaction {
  id       String @id @default(uuid())
  volumeId String
  volume   Volume @relation(fields: [volumeId], references: [id])

  type     TransactionType
  quantity Int // VD: +50 (nhập), -2 (xuất/hư hỏng)
  note     String? // VD: "Nhập sách Kim Đồng đợt 1"

  createdAt DateTime @default(now())
}

enum TransactionType {
  IMPORT
  EXPORT
  ADJUST
}

// ==========================================
// 4. CART & ORDER
// ==========================================
model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id       String @id @default(uuid())
  cartId   String
  cart     Cart   @relation(fields: [cartId], references: [id])
  volumeId String
  volume   Volume @relation(fields: [volumeId], references: [id])
  quantity Int
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  addressId   String
  address     Address     @relation(fields: [addressId], references: [id])
  totalAmount Decimal     @db.Decimal(10, 2)
  shippingFee Decimal     @db.Decimal(10, 2)
  finalAmount Decimal     @db.Decimal(10, 2)
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  status      OrderStatus @default(PENDING)

  items   OrderItem[]
  payment Payment?
}

enum OrderStatus {
  PENDING
  CONFIRMED // CẢNH SAX SAI CHÍMH TAR Sửa COFIRMED của ăng thành CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

model OrderItem {
  id       String  @id @default(uuid())
  orderId  String
  order    Order   @relation(fields: [orderId], references: [id])
  volumeId String
  volume   Volume  @relation(fields: [volumeId], references: [id])
  quantity Int
  price    Decimal @db.Decimal(10, 2)
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  method        Method
  status        StatusPayment
  transactionId String?       @unique
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
}

enum Method {
  COD
  BANK
  MOMO
  VNPAY
  ZALOPAY
  VIETQR
}

enum StatusPayment {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Review {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  seriesId  String
  series    Series    @relation(fields: [seriesId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}
