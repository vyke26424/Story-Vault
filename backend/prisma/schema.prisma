// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  email String @unique
  name String?
  password String
  avatarUrl String?
  address Address[]
  role Role @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart Cart?
  orders Order[]
  reviews Review[]
  refreshToken RefreshToken[]
}


enum Role {
  CUSTOMER
  ADMIN
  SHIPPER
}

model RefreshToken {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id])
 // token     String   @unique
  device    String?  // VD: "Chrome - Windows", "Safari - iPhone"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}


model Address {
  id String @id @default(uuid())
  userId String 
  user User @relation(fields: [userId] ,references: [id])
  phone String?
  street String?
  ward String?
  district String?
  city String?
  isDefault Boolean?

  orders Order[]
  @@index([userId, phone])
}

model Series {
  id String @id @default(uuid())
  title String 
  slug String
  description String?
  coverImage String?
  type  Type
  status Status
  totalVolumes Int?
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  volumes Volume[]
  reviews Review[]

}

enum  Type {
  MANGA
  LIGHT_NOVEL
  NOVEL 
  COMIC
  BOOK
}

enum Status {
  ONGOING
  COMPLETED
  HIATUS
}

model Volume {
  id String @id @default(uuid())
  seriesId String
  series Series @relation(fields: [seriesId], references: [id])
  title String?
  coverImage String?
  price Decimal @db.Decimal(10,2)
  originalPrice Decimal? @db.Decimal(10,2)
  stock Int 
  isbn String? @unique // mã ISBN
  publishDate DateTime? 
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems CartItem[]
  orderItems OrderItem[]


}

// nếu có thời gian thì chắc thêm tác giả với nhà xuất bản

model Category {
  id String @id @default(uuid())
  name String 
  slug String
  description String?

}


model Cart {
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id String @id @default(uuid())
  cartId String
  cart Cart @relation(fields: [cartId], references: [id])
  volumeId String
  volume Volume @relation(fields: [volumeId], references: [id])
  quantity Int 
}

model Order {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  addressId String
  address Address @relation(fields: [addressId], references: [id])
  totalAmount Decimal @db.Decimal(10,2)
  shippingFee Decimal @db.Decimal(10,2)
  finalAmount Decimal @db.Decimal(10,2)
  note String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  status OrderStatus @default(PENDING)
  items OrderItem[]
  payment Payment?
}
enum OrderStatus {
  PENDING
  COFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}
 
model OrderItem {
  id String @id @default(uuid())
  orderId String
  order Order @relation(fields: [orderId], references: [id])
  volumeId String
  volume Volume @relation(fields: [volumeId], references: [id])
  quantity Int 
  price Decimal @db.Decimal(10,2)
}

model Payment {
  id String @id @default(uuid())
  orderId String @unique
  order Order @relation(fields: [orderId], references: [id])
  method Method
  status StatusPayment
  transactionId String? @unique
  paidAt DateTime? 
  createdAt DateTime

}

enum Method {
  COD 
  BANK
  MOMO
  VNPAY
  ZALOPAY
  VIETQR
}

enum StatusPayment {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Review {
  id String @id @default(uuid())
  userId String 
  user User @relation(fields: [userId], references: [id])
  seriesId String
  series Series @relation(fields: [seriesId], references: [id])
  rating Int
  comment String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}